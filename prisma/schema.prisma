generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  fullName      String   @map("full_name") @db.VarChar(200)
  username      String   @unique @db.VarChar(50)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  role          Role     @default(USER)
  isActive      Boolean  @default(true) @map("is_active")
  isTempPassword Boolean @default(false) @map("is_temp_password")
  hasPaid       Boolean  @default(false) @map("has_paid")
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime @default(now()) @map("created_at")

  predictions         Prediction[]
  userAchievements    UserAchievement[]
  notifications       Notification[]
  rankingHistory      RankingHistory[]
  auditLogs           AuditLog[]
  topScorerPrediction TopScorerPrediction?
  paymentReceipts     PaymentReceipt[]

  @@map("users")
}

enum Role {
  ADMIN
  USER
}

model Match {
  id         String          @id @default(uuid()) @db.Uuid
  teamHome   String          @map("team_home") @db.VarChar(100)
  teamAway   String          @map("team_away") @db.VarChar(100)
  teamHomeIso String?        @map("team_home_iso") @db.VarChar(10)
  teamAwayIso String?        @map("team_away_iso") @db.VarChar(10)
  flagHome   String?         @map("flag_home") @db.VarChar(500)
  flagAway   String?         @map("flag_away") @db.VarChar(500)
  stadium    String?         @db.VarChar(150)
  city       String?         @db.VarChar(100)
  country    String?         @db.VarChar(100)
  matchDate  DateTime        @map("match_date")
  phase      String          @default("Fase de Grupos") @db.VarChar(50)
  groupLabel String?         @map("group_label") @db.VarChar(5)
  homeScore  Int?            @map("home_score")
  awayScore  Int?            @map("away_score")
  status     MatchStatus     @default(SCHEDULED)
  matchday   Int?

  predictions Prediction[]

  @@map("matches")
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  FINISHED
}

model Prediction {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  matchId        String   @map("match_id") @db.Uuid
  predictedHome  Int      @map("predicted_home")
  predictedAway  Int      @map("predicted_away")
  pointsEarned   Int?     @map("points_earned")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@map("predictions")
}

model Achievement {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(100)
  description String   @db.Text
  icon        String   @db.VarChar(50)

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  achievementId String   @map("achievement_id") @db.Uuid
  earnedAt      DateTime @default(now()) @map("earned_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar(200)
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model RankingHistory {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  position   Int
  score      Int      @default(0)
  recordedAt DateTime @default(now()) @map("recorded_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([recordedAt])
  @@map("ranking_history")
}

model SystemConfig {
  id              String    @id @default(uuid()) @db.Uuid
  knockoutEnabled Boolean   @default(false) @map("knockout_enabled")
  bettingEnabled  Boolean   @default(true) @map("betting_enabled")
  betDeadline     DateTime? @map("bet_deadline")
  betAmount       Decimal   @default(20.0) @map("bet_amount") @db.Decimal(10, 2)
  pixKey          String    @default("81986964573") @map("pix_key") @db.VarChar(100)

  @@map("system_config")
}

model PaymentReceipt {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  filePath   String   @map("file_path") @db.VarChar(500)
  fileName   String   @map("file_name") @db.VarChar(255)
  mimeType   String   @map("mime_type") @db.VarChar(50)
  notes      String?  @db.Text
  status     String   @default("PENDING") @db.VarChar(20)
  adminNotes String?  @map("admin_notes") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payment_receipts")
}

model WhatsAppSession {
  id          String   @id @default(uuid()) @db.Uuid
  sessionName String   @default("default") @map("session_name") @db.VarChar(50)
  status      String   @default("DISCONNECTED") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("whatsapp_sessions")
}

model WhatsAppGroup {
  id        String   @id @default(uuid()) @db.Uuid
  groupId   String   @unique @map("group_id") @db.VarChar(100)
  groupName String   @map("group_name") @db.VarChar(200)
  active    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("whatsapp_groups")
}

model WhatsAppNotification {
  id      String   @id @default(uuid()) @db.Uuid
  type    String   @db.VarChar(50)
  matchId String?  @map("match_id") @db.Uuid
  sentAt  DateTime @default(now()) @map("sent_at")
  success Boolean  @default(true)
  error   String?  @db.Text

  @@map("whatsapp_notifications")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String   @db.VarChar(255)
  details   String?  @db.Text
  ip        String?  @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model TopScorerPrediction {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  player1   String   @db.VarChar(150)
  player2   String   @db.VarChar(150)
  player3   String   @db.VarChar(150)
  player4   String   @db.VarChar(150)
  player5   String   @db.VarChar(150)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("top_scorer_predictions")
}
